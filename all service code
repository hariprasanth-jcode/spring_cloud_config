package cpm.user_service.user.service.service;

import org.apache.catalina.User;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import cpm.user_service.user.service.entity.UserInformation;
import cpm.user_service.user.service.repo.UserJpaRepository;

@Service
public class UserService {
	
	@Autowired
	UserJpaRepository jpa;
	
	public String create(UserInformation info) {
		jpa.save(info);
		return "Data Saved";
	}

	public UserInformation getUserById(String email) {
		
		return jpa.findById(email).orElseThrow(()->new RuntimeException("Email Id Not found"));
		// TODO Auto-generated method stub
		
	}

}
